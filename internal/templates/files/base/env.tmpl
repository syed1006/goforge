# Server
HTTP_ADDR=:8080
{{- if .GRPC }}
GRPC_ADDR=:9090
{{- end }}
LOG_LEVEL=info
{{- if eq (printf "%s" .Database) "postgres" }}

# Postgres
DATABASE_URL=postgres://postgres:postgres@localhost:5432/{{ snake .ProjectName }}?sslmode=disable
{{- end }}
{{- if eq (printf "%s" .Database) "mysql" }}

# MySQL
DATABASE_URL=root:root@tcp(localhost:3306)/{{ snake .ProjectName }}?parseTime=true
{{- end }}
{{- if eq (printf "%s" .Database) "sqlite" }}

# SQLite
DATABASE_URL=file:./{{ snake .ProjectName }}.db?cache=shared
{{- end }}
{{- if eq (printf "%s" .Database) "mongo" }}

# Mongo
MONGO_URI=mongodb://localhost:27017
MONGO_DB={{ snake .ProjectName }}
{{- end }}
{{- if eq (printf "%s" .Database) "redis" }}

# Redis
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0
{{- end }}
