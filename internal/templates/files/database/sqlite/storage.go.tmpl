// Package storage owns the database connection pool for {{ .ProjectName }}.
package storage

import (
	"context"
	"database/sql"
	"fmt"

	_ "modernc.org/sqlite"

	"{{ .ModulePath }}/internal/config"
)

// Storage wraps the database/sql handle for SQLite (pure-Go driver).
type Storage struct {
	DB *sql.DB
}

// New opens a *sql.DB against cfg.DatabaseURL and verifies connectivity with Ping.
func New(ctx context.Context, cfg *config.Config) (*Storage, error) {
	if cfg.DatabaseURL == "" {
		return nil, fmt.Errorf("storage: DATABASE_URL is empty")
	}
	db, err := sql.Open("sqlite", cfg.DatabaseURL)
	if err != nil {
		return nil, fmt.Errorf("storage: open: %w", err)
	}
	if err := db.PingContext(ctx); err != nil {
		_ = db.Close()
		return nil, fmt.Errorf("storage: ping: %w", err)
	}
	return &Storage{DB: db}, nil
}

// Close releases the underlying *sql.DB.
func (s *Storage) Close(_ context.Context) error { return s.DB.Close() }
