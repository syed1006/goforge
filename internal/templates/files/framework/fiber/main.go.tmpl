package main

import (
	"context"
	"log/slog"
	"os"
	"os/signal"
	"syscall"
	"time"

	"{{ .ModulePath }}/internal/buildinfo"
	"{{ .ModulePath }}/internal/config"
{{- if .GRPC }}
	"{{ .ModulePath }}/internal/grpcsrv"
{{- end }}
	"{{ .ModulePath }}/internal/server"
{{- if ne (printf "%s" .Database) "none" }}
	"{{ .ModulePath }}/internal/storage"
{{- end }}
{{- if .OTel }}
	"{{ .ModulePath }}/internal/telemetry"
{{- end }}
)

func main() {
	logger := slog.New(slog.NewJSONHandler(os.Stdout, nil))
	slog.SetDefault(logger)

	cfg, err := config.Load()
	if err != nil {
		logger.Error("load config", "err", err)
		os.Exit(1)
	}
{{ template "framework/_otel_block" . }}
{{ template "framework/_storage_block" . }}
	app := server.New(logger, cfg.ReadTimeout, cfg.WriteTimeout)
	logger.Info("starting", "service", "{{ .ProjectName }}", "version", buildinfo.Version, "addr", cfg.HTTPAddr)

	ctx, stop := signal.NotifyContext(context.Background(), os.Interrupt, syscall.SIGTERM)
	defer stop()

	go func() {
		if err := app.Listen(cfg.HTTPAddr); err != nil {
			logger.Error("listen", "err", err)
			stop()
		}
	}()
{{ template "framework/_grpc_block" . }}
	<-ctx.Done()
	logger.Info("shutting down")
	shutdownCtx, cancel := context.WithTimeout(context.Background(), 10*time.Second)
	defer cancel()
	if err := app.ShutdownWithContext(shutdownCtx); err != nil {
		logger.Error("shutdown", "err", err)
		os.Exit(1)
	}
}
