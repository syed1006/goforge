name: {{ snake .ProjectName }}

services:
  app:
    build:
      context: .
      dockerfile: Dockerfile
      args:
        VERSION: ${VERSION:-dev}
    image: {{ .BinaryName }}:${VERSION:-dev}
    environment:
      HTTP_ADDR: ":8080"
{{- if .GRPC }}
      GRPC_ADDR: ":9090"
{{- end }}
{{- if eq (printf "%s" .Database) "postgres" }}
      DATABASE_URL: "postgres://postgres:postgres@postgres:5432/{{ snake .ProjectName }}?sslmode=disable"
{{- end }}
{{- if eq (printf "%s" .Database) "mysql" }}
      DATABASE_URL: "root:root@tcp(mysql:3306)/{{ snake .ProjectName }}?parseTime=true"
{{- end }}
{{- if eq (printf "%s" .Database) "mongo" }}
      MONGO_URI: "mongodb://mongo:27017"
      MONGO_DB: "{{ snake .ProjectName }}"
{{- end }}
{{- if eq (printf "%s" .Database) "redis" }}
      REDIS_ADDR: "redis:6379"
{{- end }}
    ports:
      - "8080:8080"
{{- if .GRPC }}
      - "9090:9090"
{{- end }}
{{- if ne (printf "%s" .Database) "none" }}{{ if ne (printf "%s" .Database) "sqlite" }}
    depends_on:
      {{ printf "%s" .Database }}:
        condition: service_healthy
{{- end }}{{ end }}
{{- if eq (printf "%s" .Database) "postgres" }}

  postgres:
    image: postgres:16-alpine
    environment:
      POSTGRES_USER: postgres
      POSTGRES_PASSWORD: postgres
      POSTGRES_DB: {{ snake .ProjectName }}
    ports:
      - "5432:5432"
    volumes:
      - pgdata:/var/lib/postgresql/data
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U postgres"]
      interval: 5s
      timeout: 5s
      retries: 5
{{- end }}
{{- if eq (printf "%s" .Database) "mysql" }}

  mysql:
    image: mysql:8.4
    environment:
      MYSQL_ROOT_PASSWORD: root
      MYSQL_DATABASE: {{ snake .ProjectName }}
    ports:
      - "3306:3306"
    volumes:
      - mysqldata:/var/lib/mysql
    healthcheck:
      test: ["CMD", "mysqladmin", "ping", "-h", "localhost", "-uroot", "-proot"]
      interval: 5s
      timeout: 5s
      retries: 10
{{- end }}
{{- if eq (printf "%s" .Database) "mongo" }}

  mongo:
    image: mongo:7
    ports:
      - "27017:27017"
    volumes:
      - mongodata:/data/db
    healthcheck:
      test: ["CMD", "mongosh", "--quiet", "--eval", "db.adminCommand('ping').ok"]
      interval: 5s
      timeout: 5s
      retries: 10
{{- end }}
{{- if eq (printf "%s" .Database) "redis" }}

  redis:
    image: redis:7-alpine
    ports:
      - "6379:6379"
    volumes:
      - redisdata:/data
    healthcheck:
      test: ["CMD", "redis-cli", "ping"]
      interval: 5s
      timeout: 5s
      retries: 5
{{- end }}

{{- if or (eq (printf "%s" .Database) "postgres") (eq (printf "%s" .Database) "mysql") (eq (printf "%s" .Database) "mongo") (eq (printf "%s" .Database) "redis") }}

volumes:
{{- if eq (printf "%s" .Database) "postgres" }}
  pgdata:
{{- end }}
{{- if eq (printf "%s" .Database) "mysql" }}
  mysqldata:
{{- end }}
{{- if eq (printf "%s" .Database) "mongo" }}
  mongodata:
{{- end }}
{{- if eq (printf "%s" .Database) "redis" }}
  redisdata:
{{- end }}
{{- end }}
