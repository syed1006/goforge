name: ci

on:
  push:
    branches: [main, master]
  pull_request:

permissions:
  contents: read

jobs:
  test:
    name: test
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-go@v5
        with:
          go-version: "{{ .GoVersion }}"
          cache: true
{{- if .GraphQL }}
      - name: gqlgen generate
        run: go run github.com/99designs/gqlgen generate
{{- end }}
      - name: go vet
        run: go vet ./...
      - name: go test
        run: go test ./... -race -count=1
{{ if .Lint }}
  lint:
    name: lint
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-go@v5
        with:
          go-version: "{{ .GoVersion }}"
          cache: true
{{- if .GraphQL }}
      - name: gqlgen generate
        run: go run github.com/99designs/gqlgen generate
{{- end }}
      - uses: golangci/golangci-lint-action@v6
        with:
          version: latest
{{ end }}
  build:
    name: build
    runs-on: ubuntu-latest
    needs: [test]
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-go@v5
        with:
          go-version: "{{ .GoVersion }}"
          cache: true
{{- if .GraphQL }}
      - name: gqlgen generate
        run: go run github.com/99designs/gqlgen generate
{{- end }}
      - name: build
        run: |
          mkdir -p bin
          go build -trimpath -ldflags="-s -w" -o bin/{{ .BinaryName }} ./cmd/{{ .BinaryName }}
      - uses: actions/upload-artifact@v4
        with:
          name: {{ .BinaryName }}
          path: bin/{{ .BinaryName }}
